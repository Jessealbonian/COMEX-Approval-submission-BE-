# This .htaccess file is intended for use with an Apache web server acting as a reverse proxy for the Node.js application.
# It redirects all requests to the Node.js application running on the specified port (e.g., 3000).
# Make sure mod_proxy and mod_proxy_http are enabled in your Apache configuration.

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Rule to proxy API requests to the Node.js backend
  # This assumes your Node.js app is running on port 3000
  RewriteRule ^(.*)$ http://localhost:3000/$1 [P,L]
</IfModule> 